<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>會議調查管理後台</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .animate-fade-in { animation: fadeIn 0.3s ease-out forwards; }
    </style>
</head>
<body class="bg-slate-50 min-h-screen font-sans text-slate-900">

    <div class="max-w-3xl mx-auto py-12 px-6">
        <!-- 標題區 -->
        <header class="mb-12 text-center">
            <h1 class="text-4xl font-black text-slate-800 mb-4 tracking-tight">會議調查管理系統</h1>
            <p class="text-slate-500">輸入會議名稱，一鍵生成專屬調查連結</p>
        </header>

        <!-- 建立區 -->
        <div class="bg-white p-8 rounded-3xl shadow-xl border border-slate-100 mb-10">
            <div class="flex flex-col gap-6">
                <div>
                    <label class="block text-sm font-bold text-slate-600 mb-2 ml-1">會議主題名稱</label>
                    <input type="text" id="meeting-name" 
                           class="w-full bg-slate-50 border border-slate-200 rounded-2xl px-5 py-4 focus:ring-4 focus:ring-blue-100 focus:border-blue-500 outline-none transition-all font-medium text-lg" 
                           placeholder="例如：2024 年度戰略會議">
                </div>
                
                <button onclick="generateLink()" 
                        class="w-full bg-blue-600 text-white font-black py-5 rounded-2xl hover:bg-blue-700 active:scale-[0.98] transition-all shadow-xl shadow-blue-100 flex items-center justify-center gap-2 text-lg">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path></svg>
                    生成專屬連結
                </button>
            </div>
        </div>

        <!-- 結果區 -->
        <div id="result-area" class="hidden animate-fade-in">
            <div class="bg-green-50 border-2 border-green-200 p-8 rounded-3xl">
                <div class="flex items-center gap-3 mb-4 text-green-700">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    <h3 class="font-black text-xl">連結已成功生成！</h3>
                </div>
                
                <div class="space-y-4">
                    <div class="bg-white p-4 rounded-xl border border-green-100 break-all font-mono text-sm text-slate-600" id="generated-url">
                        <!-- 連結會顯示在這裡 -->
                    </div>
                    
                    <div class="flex gap-3">
                        <button onclick="copyToClipboard()" class="flex-1 bg-green-600 text-white font-bold py-3 rounded-xl hover:bg-green-700 transition flex items-center justify-center gap-2">
                            複製連結
                        </button>
                        <button onclick="window.open(document.getElementById('generated-url').innerText)" class="flex-1 bg-white text-green-600 border border-green-200 font-bold py-3 rounded-xl hover:bg-green-50 transition">
                            立即前往
                        </button>
                    </div>
                </div>
            </div>
            
            <div class="mt-8 bg-amber-50 p-6 rounded-2xl border border-amber-100 text-amber-800 text-sm">
                <p class="font-bold mb-2">💡 小撇步：</p>
                <ul class="list-disc ml-5 space-y-1 opacity-80">
                    <li>您可以將此連結發送到 Line 或 Slack 群組。</li>
                    <li>同一個會議主題會共用同一份時間表。</li>
                    <li>系統會自動在 Google 試算表中建立獨立的分頁來存放此會議資料。</li>
                </ul>
            </div>
        </div>
    </div>

    <!-- 訊息彈窗 -->
    <div id="toast" class="fixed bottom-10 left-1/2 -translate-x-1/2 bg-slate-800 text-white px-8 py-4 rounded-2xl shadow-2xl hidden z-50 text-sm font-bold animate-fade-in"></div>

    <script>
        function showMessage(msg) {
            const toast = document.getElementById('toast');
            toast.innerText = msg;
            toast.classList.remove('hidden');
            setTimeout(() => toast.classList.add('hidden'), 2000);
        }

        function generateLink() {
            const nameInput = document.getElementById('meeting-name');
            const name = nameInput.value.trim();
            
            if (!name) {
                showMessage('⚠️ 請輸入會議名稱');
                return;
            }

            // 1. 取得 index.html 的基礎路徑 (假設在同一個資料夾)
            const currentPath = window.location.href.substring(0, window.location.href.lastIndexOf('/') + 1);
            const targetBase = currentPath + 'index.html';

            // 2. 生成唯一的 Room ID (使用時間戳 + 隨機數)
            const roomId = 'room_' + Date.now() + Math.floor(Math.random() * 1000);

            // 3. 組合連結 (包含 room ID 和 編碼過的標題)
            const finalUrl = `${targetBase}?room=${roomId}&title=${encodeURIComponent(name)}`;

            // 4. 顯示結果
            document.getElementById('generated-url').innerText = finalUrl;
            document.getElementById('result-area').classList.remove('hidden');
            
            showMessage('✨ 連結生成完畢！');
        }

        function copyToClipboard() {
            const urlText = document.getElementById('generated-url').innerText;
            const tempInput = document.createElement("input");
            tempInput.value = urlText;
            document.body.appendChild(tempInput);
            tempInput.select();
            document.execCommand("copy");
            document.body.removeChild(tempInput);
            showMessage('📋 已複製到剪貼簿');
        }
    </script>
</body>
</html>
